        function tambahkanListener(){
            const inputHarga = document.querySelectorAll(".pisah input.editin");
            const inputFoto = document.querySelectorAll(".pisah input[type='file']");

            const tampilanHarga = document.querySelectorAll(".harga");
            const tampilanFoto = document.querySelectorAll(".foto img");

            console.log(inputHarga);
            console.log(tampilanHarga);

            inputHarga.forEach((input, i) => {
                input.addEventListener("input", function(){
                    tampilanHarga[i].innerHTML = input.value;
                });
            });
            inputFoto.forEach((input, i) => {
                input.addEventListener("change", function(){
                    const file = event.target.files[0];
                    if (file) {
                        const fileUrl = URL.createObjectURL(file);
                        
                        tampilanFoto[i].src = fileUrl;
                    } else {
                        tampilanFoto[i].src = '/images/contoh/armoredMachine.jpg';
                    }

                });
            });
        }
        
