    <script>
        function downloadGambar() {
            document.querySelector(".poster").style.border = "none";
            // Tampilkan loading spinner jika ada (proses render HD butuh waktu di HP)
            // contoh: document.getElementById('loading').style.display = 'block';

            // Pilih elemen HTML yang ingin difoto
            const elemen = document.getElementById('poster');

            // --- TRIK UNTUK MAKSIMAL HD ---
            // 1. Ambil ukuran asli elemen
            const originalW = elemen.offsetWidth;
            const originalH = elemen.offsetHeight;

            // 2. Tentukan seberapa besar perkalian resolusinya (contoh: 3x lipat)
            const multiplier = 3; 

            // Gunakan html2canvas dengan konfigurasi canggih
            html2canvas(elemen, {
                useCORS: true,         // Wajib agar foto user muncul
                allowTaint: true,      
                scale: multiplier,     // Mengalikan resolusi kanvas
                
                // Atur ukuran kanvas secara spesifik agar pas dengan skala
                width: originalW,
                height: originalH,
                windowWidth: originalW,
                windowHeight: originalH,

                // Memberi tahu browser untuk merender dengan prioritas kualitas teks/gambar tinggi
                onclone: (clonedDoc) => {
                    // Opsional: Kamu bisa memanipulasi elemen di dalam kloningan di sini
                    // sebelum dirender, jika perlu.
                }
            }).then(function(canvas) {
                // Ubah hasil render menjadi URL data gambar
                const linkGambar = canvas.toDataURL("image/png");

                // Buat tag link <a> untuk memicu unduhan
                const linkDownload = document.createElement('a');
                linkDownload.href = linkGambar;
                linkDownload.download = 'hasil-gambar-hd.png';

                // Klik link tersebut secara otomatis
                linkDownload.click();

                // Sembunyikan loading spinner
                // contoh: document.getElementById('loading').style.display = 'none';
            }).catch(function(error) {
                console.error("Gagal capture HD:", error);
            });
        }
    </script>
