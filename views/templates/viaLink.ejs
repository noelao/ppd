<style>/* Gaya Dasar Tombol */
.btn-utama {
  background-color: #3b82f6; /* Warna biru utama */
  color: #ffffff; /* Warna teks putih */
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  font-size: 14px;
  font-weight: 600;
  border: none;
  border-radius: 6px; /* Menyesuaikan lengkungan input */
  padding: 10px 16px;
  cursor: pointer;
  transition: all 0.2s ease-in-out;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%; /* Membuat tombol memenuhi lebar kotak */
  margin-top: 8px; /* Jarak dari opsi terakhir */
}

/* Efek saat mouse berada di atas tombol (Hover) */
.btn-utama:hover {
  background-color: #2563eb; /* Biru yang lebih gelap */
  box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2), 
              0 2px 4px -1px rgba(59, 130, 246, 0.1);
}

/* Efek saat tombol diklik (Active) */
.btn-utama:active {
  background-color: #1d4ed8; /* Biru paling gelap */
  transform: scale(0.98); /* Efek tombol tertekan sedikit */
}

/* Efek saat tombol menggunakan navigasi keyboard (Focus) */
.btn-utama:focus {
  outline: none;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
}

/* Gaya jika tombol di-disable (Opsional) */
.btn-utama:disabled {
  background-color: #9ca3af;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}</style>

    <style>
        * {
            padding: 0;
            margin: 0;
            box-sizing: border-box;
        }
        body {
            font-family: header;
        }
        .container {
            width: 100%;
            min-height: 100vh;

            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            gap: 1rem;
        }
        .poster {
            padding: 1rem;
            border: solid 1px #000;
            width: 100%;
            aspect-ratio: 1;

            display: flex;
            flex-direction: column;
            position: relative;
            background-color: #fff;
            .header {
                width: 100%;
                text-align: center;
                font-size: 2rem;
            }
            .kotakan {

                width: 100%;
                font-family: subHeader;
                line-height: 1;
                display: flex;
                flex-direction: column;
                gap: .1rem;

                small.jenis {
                    font-size: .5rem;
                    padding-top: .3rem;
                }

                .wadah {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: .3rem;
                    .foto {
                        width: 100%;
                        height: 2.9rem;

                        display: flex;
                        overflow: hidden;
                        border-radius: .75rem;
                        position: relative;
                        img {
                            z-index: 0;
                            position: absolute;
                            top: 0;
                            left: 0;


                            min-width: 100%;
                            min-height: 100%;
                            height: 100%;
                            width: 100%;
                            object-fit: cover;
                        }
                        .text {
                            z-index: 1;
                            position: absolute;
                            right: .6rem;
                            bottom: -.1rem;
                            font-size: 1.3rem;

                            color: white;text-shadow: 1px 1px 0 #aaa, 
                                2px 2px 0 #777777, 
                                3px 3px 0 #777777, 
                                4px 4px 0 #505050;
                        }
                    }
                }
            }
            .bawahan {
                width: 100%;
                display: flex;
                justify-content: space-between;

                position: absolute;
                bottom: 0;
                left: 0;
                padding: .8rem;
                .namaStore {

                }
                .qrCode {
                    width: 4rem;
                    aspect-ratio: 1;
                    border-radius: .75rem;
                    border: solid 1px #767676;
                    overflow: hidden;

                    img {
                        min-width: 100%;
                        min-height: 100%;
                        height: 100%;
                        object-fit: cover;
                    }
                }

            }
        }
    </style>
</head>
