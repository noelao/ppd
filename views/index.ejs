<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Pilih Template</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      height: 100%;
      background: #111113;
      color: #f0ede6;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    body {
      max-width: 430px;
      margin: 0 auto;
      padding: 48px 16px 32px;
    }

    h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 6px;
    }

    .subtitle {
      font-size: 13px;
      color: #555;
      margin-bottom: 28px;
    }

    .cards {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .tcard {
      display: flex;
      align-items: center;
      background: #18181c;
      border: 0.5px solid #2a2a30;
      border-radius: 16px;
      overflow: hidden;
      text-decoration: none;
      transition: border-color 0.15s, transform 0.1s;
    }

    .tcard:active {
      transform: scale(0.98);
      border-color: #5a5ae0;
    }

    .tcard-strip {
      width: 4px;
      align-self: stretch;
      flex-shrink: 0;
    }

    .tcard-img {
      width: 90px;
      height: 90px;
      flex-shrink: 0;
      background: #1e1e24;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .tcard-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .tcard-body {
      flex: 1;
      padding: 14px 16px;
    }

    .tcard-name {
      font-size: 15px;
      font-weight: 600;
      color: #f0ede6;
      margin-bottom: 4px;
    }

    .tcard-desc {
      font-size: 12px;
      color: #555;
      line-height: 1.5;
    }

    .tcard-arrow {
      padding-right: 16px;
      color: #333;
      font-size: 20px;
      line-height: 1;
    }
  </style>
</head>
<body>

  <h1>Pilih Template</h1>
  <p class="subtitle">Tinggal isi teks &amp; tambah gambar</p>

  <div class="cards">

    <a class="tcard jualLink" href="/template/viaLink">
      <div class="tcard-strip" style="background:#3a3aaa;"></div>
      <div class="tcard-img">
        <img src="/images/logoTemplate/viaLink.png" alt="Jual Link">
      </div>
      <div class="tcard-body">
        <p class="tcard-name">Jual via Link</p>
        <p class="tcard-desc">Isi judul, deskripsi &amp; link produk</p>
      </div>
      <span class="tcard-arrow">›</span>
    </a>

    <a class="tcard captionFoto" href="#">
      <div class="tcard-strip" style="background:#1a7a4a;"></div>
      <div class="tcard-img">
        <img src="/images/logoTemplate/captionFoto.png" alt="Caption Foto">
      </div>
      <div class="tcard-body">
        <p class="tcard-name">Caption Foto</p>
        <p class="tcard-desc">Upload foto &amp; isi caption</p>
      </div>
      <span class="tcard-arrow">›</span>
    </a>

  </div>

</body>
</html>